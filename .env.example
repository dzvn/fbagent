# Facebook Configuration
FB_VERIFY_TOKEN=fbagent_verify_2026
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
WEBHOOK_URL=https://your-domain.com/webhook

# API Authentication
API_KEY=your-secure-api-key-here

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=
LLM_TEMPERATURE=0.7

# OpenAI (if using OpenAI models)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (if using Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Ollama (if using self-hosted models)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/fbagent
REDIS_URL=redis://localhost:6380

# App Settings
NODE_ENV=development
PORT=9000
